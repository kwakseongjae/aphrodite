---
import Layout from "../../layouts/Layout.astro";
import ComponentDemo from "../../components/ComponentDemo";
import NAMES, { CATALOG } from "../../content/component-list";

export function getStaticPaths() {
  return NAMES.map((name) => ({ params: { name } }));
}

const { name } = Astro.params as { name: string };
const tagline = CATALOG[name]?.tagline ?? "";
---
<Layout title={name}>
  <h1>{name}</h1>
  <p class="lede">{tagline}</p>

  <h2>Demo</h2>
  <div class="docs-demo">
    <ComponentDemo client:load name={name} />
  </div>

  <h2>Usage</h2>
  <pre class="docs-snippet"><code>{`import { ${name} } from "@yourorg/yourbrand";

<${name} />`}</code></pre>

  <h2>SSR</h2>
  <p><code>{name}</code> 컴포넌트는 Next.js 14 App Router + Vite + Remix v2에서 모두 build / hydration / themed-render 통과합니다. 컴포넌트 파일 첫 줄에 <code>"use client"</code> directive가 자동 prepend되므로 RSC environment에서도 안전합니다.</p>

  <h2>Source</h2>
  <p><a href={`https://github.com/kwakseongjae/aphrodite/blob/main/tests/ssr/fixtures/banchan-react/src/${name}.tsx`} target="_blank" rel="noopener noreferrer">GitHub에서 보기 ↗</a></p>
</Layout>
